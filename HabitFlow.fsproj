<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>HabitFlow</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="src/Types.fs" />
    <Compile Include="src/Logic.fs" />
    <Compile Include="src/Storage.fs" />
    <Compile Include="src/State.fs" />
    <Compile Include="src/View.fs" />
    <Compile Include="src/App.fs" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Fable" Version="4.24.0" />
    <PackageReference Include="Fable.Browser.Dom" Version="2.18.0" />
    <PackageReference Include="Fable.Core" Version="4.3.0" />
    <PackageReference Include="Feliz" Version="2.9.0" />
    <PackageReference Include="Feliz.UseElmish" Version="1.1.0" />
    <PackageReference Include="Elmish" Version="4.3.0" />
    <PackageReference Include="Elmish.React" Version="4.0.0" />
  </ItemGroup>
</Project>
